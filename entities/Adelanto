{
  "name": "Adelanto",
  "type": "object",
  "properties": {
    "empleado_id": {
      "type": "string",
      "description": "ID del empleado"
    },
    "empleado_nombre": {
      "type": "string",
      "description": "Nombre del empleado (denormalizado)"
    },
    "monto": {
      "type": "number",
      "description": "Monto del adelanto en USD"
    },
    "moneda": {
      "type": "string",
      "enum": [
        "USD",
        "VES",
        "COP"
      ],
      "default": "USD",
      "description": "Moneda del adelanto (siempre USD)"
    },
    "fecha_adelanto": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha y hora del adelanto"
    },
    "metodo_pago": {
      "type": "string",
      "enum": [
        "efectivo_usd",
        "tarjeta_bs",
        "pago_movil_bs",
        "binance_usd",
        "zinli_usd",
        "nequi_cop",
        "paypal_usd",
        "zelle_usd"
      ],
      "description": "M\u00e9todo de pago del adelanto"
    },
    "estado": {
      "type": "string",
      "enum": [
        "pendiente",
        "descontado"
      ],
      "default": "pendiente",
      "description": "Estado del adelanto"
    },
    "notas": {
      "type": "string",
      "description": "Notas adicionales"
    },
    "fecha_descuento": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha en que se descont\u00f3 del pago"
    }
  },
  "required": [
    "empleado_id",
    "empleado_nombre",
    "monto",
    "fecha_adelanto",
    "metodo_pago"
  ]
}