generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Venta {
  id              String         @id @default(uuid())
  fecha_hora      DateTime       @default(now())
  total_venta     Float
  metodo_pago     String?
  total_cop       Float?
  total_ves       Float?
  monto_original  Float?
  moneda_original String?
  detalles        DetalleVenta[]
  estado          String         @default("ACTIVO")
  createdAt       DateTime       @default(now())

  @@index([fecha_hora])
}

model DetalleVenta {
  id             String  @id @default(uuid())
  ventaId        String
  venta          Venta   @relation(fields: [ventaId], references: [id])
  platoId        String?
  platoNombre    String?
  cantidad       Float
  precioUnitario Float
  subtotal       Float
}

model Ingrediente {
  id                  String  @id @default(uuid())
  nombre              String
  cantidad_disponible Float   @default(0)
  cantidad_minima     Float   @default(0)
  unidad_medida       String?
  unidad_receta       String?
  factor_conversion   Float   @default(1)
  costo_por_unidad    Float?
  proveedor           String?
  createdAt           DateTime @default(now())
}

model Plato {
  id            String   @id @default(uuid())
  nombre        String
  descripcion   String?
  precio        Float    @default(0)
  categoria     String?
  activo        Boolean  @default(true)
  tiene_piezas  Boolean  @default(false)
  permitir_merma Boolean @default(false)
  permitir_credito_empleado Boolean @default(false)
  precio_6      Float    @default(0)
  precio_12     Float    @default(0)
  costo_total   Float    @default(0)
  precio_sugerido Float  @default(0)
  recetas       Receta[]
  createdAt     DateTime @default(now())
}

model Receta {
  id                String  @id @default(uuid())
  platoId           String
  plato             Plato   @relation(fields: [platoId], references: [id])
  ingredienteId     String
  ingredienteNombre String?
  tipo              String?  @default("ingrediente") // ingrediente, receta_primaria, receta_secundaria, plato
  cantidad_requerida Float
  costo_ingrediente Float?   @default(0)
}

model Comanda {
  id             String  @id @default(uuid())
  numero_comanda String
  mesa_numero    String?
  mesero_nombre  String?
  fecha_apertura DateTime @default(now())
  fecha_cierre   DateTime?
  estado         String   @default("abierta")
  tipo_movimiento String  @default("VENTA")
  empleado_id    String?
  motivo_merma   String?
  total_comanda  Float    @default(0)
  detalles       DetalleComanda[]

  @@index([fecha_apertura])
  @@index([estado])
}

model DetalleComanda {
  id          String  @id @default(uuid())
  comandaId   String
  comanda     Comanda @relation(fields: [comandaId], references: [id])
  platoId     String?
  platoNombre String?
  cantidad    Float
  precio      Float
  estado_plato String @default("pendiente")
  notas_plato  String?
  variante     String?
}

model Adelanto {
  id         String   @id @default(uuid())
  empleadoId String?
  empleado   String?
  monto      Float
  monto_pendiente Float?
  monto_descontado Float? @default(0)
  monto_original  Float?
  moneda_original String?
  tasa_cambio     Float?
  metodo_pago     String?
  fecha      DateTime @default(now())
  descripcion String?
  estado          String?  @default("PENDIENTE")
  fecha_descuento DateTime?
  nomina_id       String?
  createdAt  DateTime @default(now())

  @@index([estado])
}

model AlertaStock {
  id                String   @id @default(uuid())
  ingredienteId     String?
  ingredienteNombre String?
  cantidad_actual   Float?
  cantidad_minima   Float?
  creadoEn          DateTime @default(now())

  @@index([ingredienteId])
}

model CategoriaGasto {
  id          String   @id @default(uuid())
  nombre      String
  descripcion String?
  createdAt   DateTime @default(now())
}

model DetalleRecetaPrimaria {
  id                 String  @id @default(uuid())
  recetaPrimariaId   String
  recetaPrimaria     RecetaPrimaria @relation(fields: [recetaPrimariaId], references: [id])
  ingredienteId      String?
  ingredienteNombre  String?
  tipoElemento       String?  // ingrediente, receta_primaria
  cantidad           Float
  unidadMedida       String?
  costoIngrediente   Float?   @default(0)
}

model DetalleRecetaSecundaria {
  id                 String  @id @default(uuid())
  recetaSecundariaId String
  recetaSecundaria   RecetaSecundaria @relation(fields: [recetaSecundariaId], references: [id])
  elementoId         String?
  elementoNombre     String?
  tipoElemento       String?  // ingrediente, receta_primaria
  cantidad           Float
  unidadMedida       String?
  costoElemento      Float?   @default(0)
}

model SesionUsuario {
  id         String   @id @default(uuid())
  usuarioId  String?
  usuario    Usuario? @relation(fields: [usuarioId], references: [id])
  token      String?
  creadoEn   DateTime @default(now())
  expiracion DateTime?
}

model Compra {
  id        String   @id @default(uuid())
  proveedor String?
  total     Float    @default(0)
  fecha     DateTime @default(now())
}

model CuentaPorCobrar {
  id            String   @id @default(uuid())
  clienteNombre String?
  empleadoId    String?
  monto         Float
  monto_total   Float?   @default(0)
  monto_pendiente Float? @default(0)
  monto_descontado Float? @default(0)
  estado        String   @default("pendiente")
  fecha_creacion DateTime @default(now())
  vencimiento   DateTime?
  comanda_numero String?
  cliente_telefono String?
}

model Empleado {
  id           String   @id @default(uuid())
  nombre       String
  usuario      String?  @unique // Username para login
  password     String?  // Password hasheado para autenticación
  rol          String?
  activo       Boolean  @default(true)
  salario_base Float    @default(0)
  cargo        String?
  cedula       String?
  telefono     String?
  createdAt    DateTime @default(now())
}

model Nomina {
  id               String   @id @default(uuid())
  empleado_id      String?
  empleado_nombre  String?
  periodo_inicio   DateTime?
  periodo_fin      DateTime?
  salario_base     Float    @default(0)
  total_adelantos  Float    @default(0)
  total_cuentas    Float    @default(0)
  salario_neto     Float    @default(0)
  metodo_pago      String?
  moneda_pago      String?  @default("USD")
  tasa_cambio      Float    @default(1)
  monto_convertido Float    @default(0)
  estado           String?  @default("PAGADO")
  notas            String?
  fecha_pago       DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([empleado_id])
  @@index([fecha_pago])
}

model Gasto {
  id            String   @id @default(uuid())
  categoriaId   String?
  categoriaNombre String?
  monto         Float
  monto_original Float?
  moneda_original String?
  metodo_pago   String?
  descripcion   String?
  fecha         DateTime @default(now())
  estado        String   @default("ACTIVO")

  @@index([fecha])
}

model HistorialCostoIngrediente {
  id             String   @id @default(uuid())
  ingredienteId  String
  costoAnterior  Float?
  costoNuevo     Float?
  fecha          DateTime @default(now())
}

model LogLimpieza {
  id          String   @id @default(uuid())
  ubicacion   String?
  realizadoPor String?
  fecha       DateTime @default(now())
  notas       String?
}

model PagoCuentaPorCobrar {
  id        String   @id @default(uuid())
  cuenta_id String?
  cuentaId  String?
  monto     Float?
  monto_pagado Float?
  fecha     DateTime @default(now())
  fecha_pago DateTime @default(now())
  metodo    String?
  metodo_pago String?
  tasa_bs_aplicada Float?
  notas     String?
  empleado_nombre String?
}

model PagoMixto {
  id          String   @id @default(uuid())
  ventaId     String?
  monto       Float
  monto_usd   Float?
  monto_original Float?
  moneda      String?
  metodo_pago String?
  fecha       DateTime @default(now())
}

model RecetaPrimaria {
  id                  String  @id @default(uuid())
  nombre              String
  descripcion         String?
  unidadMedida        String?  // kg, g, l, ml, unidad, porcion
  cantidadResultante  Float    @default(1)
  costoTotal          Float    @default(0)
  costoPorUnidad      Float    @default(0)
  tiempoPreparacion   Int?
  instrucciones       String?
  activa              Boolean @default(true)
  detalles            DetalleRecetaPrimaria[]
}

model RecetaSecundaria {
  id                  String  @id @default(uuid())
  nombre              String
  descripcion         String?
  unidadMedida        String?  // kg, g, l, ml, unidad, porcion
  cantidadResultante  Float    @default(1)
  costoTotal          Float    @default(0)
  costoPorUnidad      Float    @default(0)
  tiempoPreparacion   Int?
  instrucciones       String?
  activa              Boolean @default(true)
  detalles            DetalleRecetaSecundaria[]
}

model TasaCambio {
  id              String   @id @default(uuid())
  fecha           String?
  tasa_bs_usd     Float?
  tasa_cop_usd    Float?
  activa          Boolean  @default(true)
  empleado_nombre String?
  created_date    DateTime @default(now())
}

model Usuario {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  nombre    String
  rol       String   @default("administrador")
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  sesiones  SesionUsuario[]
}

model ArqueoCaja {
  id        String   @id @default(uuid())
  fecha     DateTime @default(now())
  estado    String   @default("ACTIVO")
}

model ReporteTrimestral {
  id                  String   @id @default(uuid())
  periodo             String
  fechaInicio         DateTime
  fechaFin            DateTime
  totalNominasPagadas Float
  totalAdelantos      Float
  totalIngresosCaja   Float
  totalEgresosCaja    Float
  zelle               Float    @default(0)
  binance             Float    @default(0)
  nequi               Float    @default(0)
  paypal              Float    @default(0)
  zinli               Float    @default(0)
  efectivo_usd        Float    @default(0)
  efectivo_cop        Float    @default(0)
  efectivo_bs         Float    @default(0)
  pago_movil          Float    @default(0)
  punto_venta         Float    @default(0)
  createdAt           DateTime @default(now())
}

